rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY:
     * This ruleset implements a hybrid Role-Based Access Control (RBAC) and Ownership model.
     * 1. Authorization Independence: Documents like Invoices and InvoiceLineItems carry 
     *    denormalized authorization fields (e.g., ownerUserId, issuingBranchId) to 
     *    avoid expensive cross-document lookups.
     * 2. DBAC (Database-Backed Access Control): Global roles (Admin, MPO, Branch Manager) 
     *    are stored in a dedicated /user_roles collection.
     * 3. Prototyping Flexibility: Rules strictly enforce 'who' can access data but 
     *    are permissive regarding 'what' the data looks like (schema flexibility), 
     *    except for critical relational links like owner IDs.
     * 4. Structural Segregation: Administrative settings and product catalogs are 
     *    globally readable but restricted to administrative writes.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Retrieves the role of the authenticated user from the user_roles collection. */
    function getUserRole() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role;
    }

    /** Checks if the user has an 'admin' role. */
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    /** Checks if the user is a Medical Promotion Officer (MPO). */
    function isMPO() {
      return isSignedIn() && getUserRole() == 'mpo';
    }

    /** Simple ownership check based on a UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Secure ownership check for existing documents (updates/deletes). */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for global company settings. Static singleton access.
     * @path /company_settings/apex_pharma_ltd
     * @allow (get, list) if any signed-in user.
     * @deny (create, update, delete) if user is not an admin.
     * @principle Restricts global configuration to administrators while allowing public read for branding.
     */
    match /company_settings/apex_pharma_ltd {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      /**
       * @description Rules for company branches.
       * @path /company_settings/apex_pharma_ltd/branches/{branchId}
       * @allow (get, list) if signed in.
       * @deny (write) if not admin.
       * @principle Hierarchical access control for organizational units.
       */
      match /branches/{branchId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Access for customer profiles.
     * @path /customers/{customerId}
     * @allow (get, list) if signed in.
     * @allow (create, update) if MPO or Admin (to manage their client base).
     * @deny (delete) if not admin.
     * @principle Allows sales staff to manage their customer list while protecting records from deletion.
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create, update: if isAdmin() || isMPO();
      allow delete: if isAdmin();
    }

    /**
     * @description Employee profile records.
     * @path /employees/{employeeId}
     * @allow (get, list) if signed in (for internal directory/lookup).
     * @deny (write) if not admin.
     * @principle Protects employee metadata and identity mapping.
     */
    match /employees/{employeeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Product catalog access.
     * @path /products/{productId}
     * @allow (get, list) if signed in.
     * @deny (write) if not admin.
     * @principle Ensures product pricing and data integrity is managed centrally.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Main Invoice collection. Ownership is defined by 'ownerUserId'.
     * @path /invoices/{invoiceId}
     * @allow (get, list) if user is the 'ownerUserId' or an admin.
     * @allow (create) if the user sets themselves as the 'ownerUserId'.
     * @allow (update, delete) if the user is the existing owner.
     * @principle Enforces data silo per MPO while allowing administrative oversight.
     */
    match /invoices/{invoiceId} {
      allow get, list: if isAdmin() || isOwner(resource.data.ownerUserId);
      allow create: if isOwner(request.resource.data.ownerUserId);
      allow update: if isAdmin() || (isExistingOwner(resource.data.ownerUserId) && request.resource.data.ownerUserId == resource.data.ownerUserId);
      allow delete: if isAdmin() || isExistingOwner(resource.data.ownerUserId);

      /**
       * @description Line items for invoices. Inherits ownership via denormalized fields.
       * @path /invoices/{invoiceId}/line_items/{lineItemId}
       * @allow (create, update, delete) if ownerUserId matches authenticated user.
       * @principle Uses denormalization to avoid parent 'get()' calls for line-item security.
       */
      match /line_items/{lineItemId} {
        allow get, list: if isAdmin() || isOwner(resource.data.ownerUserId);
        allow create: if isOwner(request.resource.data.ownerUserId);
        allow update: if isAdmin() || (isExistingOwner(resource.data.ownerUserId) && request.resource.data.ownerUserId == resource.data.ownerUserId);
        allow delete: if isAdmin() || isExistingOwner(resource.data.ownerUserId);
      }
    }

    /**
     * @description Database-Backed Access Control (DBAC) role configuration.
     * @path /user_roles/{userId}
     * @allow (get) if the user is reading their own role or is admin.
     * @deny (list) if not admin (prevents user enumeration).
     * @deny (write) if not admin.
     * @principle Source of truth for all authorization logic; strictly managed by admins.
     */
    match /user_roles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}